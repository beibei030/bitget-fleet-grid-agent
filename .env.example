# 环境变量 — 复制为 .env 后填写（勿提交 .env）

# Bitget Demo Trading API（Live Demo 挂单）
BITGET_API_KEY=your-demo-api-key
BITGET_SECRET_KEY=your-secret-key
BITGET_PASSPHRASE=your-passphrase

# 网格参数（默认 = VPS Decibel DEC_CRYPTO_GRID）
GRID_SYMBOL=SOLUSDT
GRID_BALANCE_USD=1000
GRID_LEVERAGE=5
GRID_COUNT=22
GRID_RANGE_HALF_PCT=0.024
GRID_BUDGET_USE=0.85

# TS 回测
BACKTEST_DAYS=30
BACKTEST_BALANCE=1000
PAPER_SYMBOL=SOLUSDT
PAPER_DAYS=7
